    },
    "estado": {
      "type": "string",
      "description": "Estado principal do bloco"
    },
    "responsavel_principal": {
      "type": "string"
    },
    "responsavel_email": {
      "type": "string"
    },
    "responsavel_telefone": {
      "type": "string"
